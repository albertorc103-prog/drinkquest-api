// DrinkQuest — PostgreSQL schema (UUID, soft delete, audit fields)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  BAR
  ADMIN
  SUPER_ADMIN
}

enum ProfileVisibility {
  PUBLIC
  PRIVATE
}

enum FriendRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum QrSessionStatus {
  ACTIVE
  USED
  EXPIRED
}

enum DrinkRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

enum MissionStatus {
  LOCKED
  IN_PROGRESS
  COMPLETED
  CLAIMED
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

enum ReportTargetType {
  USER
  POST
  COMMENT
  BAR
  MESSAGE
}

enum NotificationType {
  FRIEND_REQUEST
  FRIEND_ACCEPTED
  CHAT_MESSAGE
  QR_UNLOCK
  MISSION_COMPLETE
  FEED_LIKE
  FEED_COMMENT
  SYSTEM
  SPECIAL_DRINK_APPROVED
  SPECIAL_DRINK_REJECTED
  SPECIAL_DRINK_FLAGGED
  SPECIAL_DRINK_PUBLISHED
  PROMOTION_APPROVED
  PROMOTION_REJECTED
  PROMOTION_FLAGGED
  PROMOTION_PUBLISHED
  ROOFTOP_VERIFIED
  ROOFTOP_REJECTED
  ROOFTOP_PACKAGE_APPROVED
  ROOFTOP_PACKAGE_REJECTED
  ROOFTOP_PACKAGE_FLAGGED
  ROOFTOP_PACKAGE_PUBLISHED
  RESERVATION_CREATED
  RESERVATION_CONFIRMED
  RESERVATION_DECLINED
  RESERVATION_CANCELLED
  GLOBAL_EVENT_PROGRESS
  GLOBAL_EVENT_COMPLETED
}

/// Ciclo de vida de la suscripción SaaS del local (manual o Stripe en fases futuras).
enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

/// Plan comercial del local (Explorer $499, Intermedio $1000, Legend $1500).
enum SubscriptionPlan {
  EXPLORER
  INTERMEDIATE
  LEGEND
  BASIC
  PRO
}

/// Eventos de ciclo de vida (admin, sistema, Stripe futuro).
enum SubscriptionEventType {
  ACTIVATED
  SUSPENDED
  REACTIVATED
  TRIAL_EXTENDED
  QR_ENABLED
  QR_DISABLED
  PROMO_ENABLED
  PROMO_DISABLED
  STATUS_CHANGED
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

enum PromotionPlacementType {
  STANDARD
  FEATURED
  BOOSTED
}

/// Temática de evento Happy Hour (Legend). STANDARD = promo normal.
enum PromotionEventTheme {
  STANDARD
  CHRISTMAS
  NEW_YEAR
  HALLOWEEN
  NOCHE_MEXICANA
  ANNIVERSARY
}

/// Verificación admin de terraza/jardín (Legend → sección Rooftop).
enum RooftopVerificationStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum RooftopPackageStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RooftopPackageApprovalStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  FLAGGED
}

enum PromotionApprovalStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  FLAGGED
}

enum PromotionEventType {
  APPROVAL
  REJECTION
  FLAGGING
  ACTIVATION
  PAUSE
  RESUBMISSION
}

enum PromotionAnalyticsEventType {
  IMPRESSION
  OPEN
  QR_SCAN
}

enum SpecialDrinkApprovalStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  FLAGGED
}

enum SpecialDrinkStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum VenueEventStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum VenueEventModerationStatus {
  VISIBLE
  REMOVED
}

/// Plantillas sanas de misiones del local (Legend). Sin consumo excesivo.
enum BarMissionTemplate {
  SCAN_ONCE
  SCAN_TWO_DAYS
  SCAN_TWO_DRINKS
  /// Reservar mesa para al menos 2 personas (sin depósito).
  RESERVE_PARTY_OF_TWO
}

enum BarMissionSeasonStatus {
  DRAFT
  ACTIVE
  ENDED
}

/// Reserva de mesa (Legend). Solo nombre, personas y fecha — sin depósito.
enum BarReservationStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
  COMPLETED
}

/// Eventos globales gestionados por DrinkQuest (solo bares Legend en el pool).
enum GlobalEventStatus {
  DRAFT
  ACTIVE
  ENDED
}

enum GlobalEventGoalType {
  /// Desbloquear bebida (QR) en N bares distintos del pool Legend.
  VISIT_BARS
}

enum FeedPostType {
  USER
  UNLOCK
  VISIT
  ACHIEVEMENT
}

enum MagazineSection {
  STRONG
  PARA_DATE
}

model User {
  id                String            @id @default(uuid()) @db.Uuid
  email             String            @unique
  passwordHash      String            @map("password_hash")
  displayName       String            @map("display_name")
  bio               String?
  avatarUrl         String?           @map("avatar_url")
  role              Role              @default(USER)
  profileVisibility ProfileVisibility @default(PUBLIC) @map("profile_visibility")
  emailVerified     Boolean           @default(false) @map("email_verified")
  emailVerifiedAt   DateTime?         @map("email_verified_at")
  isOnline          Boolean           @default(false) @map("is_online")
  lastSeenAt        DateTime?         @map("last_seen_at")
  totalXp           Int               @default(0) @map("total_xp")
  level             Int               @default(1)
  coins             Int               @default(0)
  loginStreakDays   Int               @default(0) @map("login_streak_days")
  lastLoginEpochDay Int               @default(0) @map("last_login_epoch_day")
  streakBonusTierClaimed Int          @default(0) @map("streak_bonus_tier_claimed")
  dailyChestClaimedDay Int            @default(0) @map("daily_chest_claimed_day")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")

  refreshTokens       RefreshToken[]
  emailVerifications  EmailVerification[]
  passwordResets      PasswordReset[]
  bar                 Bar?
  sentFriendRequests  FriendRequest[]     @relation("FriendRequestSender")
  receivedFriendRequests FriendRequest[]  @relation("FriendRequestReceiver")
  friendshipsA        Friendship[]          @relation("FriendshipUserA")
  friendshipsB        Friendship[]          @relation("FriendshipUserB")
  blocksInitiated     UserBlock[]           @relation("BlockInitiator")
  blocksReceived      UserBlock[]           @relation("BlockTarget")
  chatMemberships     ChatParticipant[]
  messagesSent        ChatMessage[]
  messageReads        MessageRead[]
  drinkUnlocks        UserDrinkUnlock[]
  drinkHistory        DrinkHistoryEntry[]
  favoriteDrinks      UserFavoriteDrink[]
  userMissions        UserMission[]
  userAchievements    UserAchievement[]
  userBarMissionProgress UserBarMissionProgress[]
  userBarMedals       UserBarMedal[]
  barReservations     BarReservation[]
  globalEventProgress UserGlobalEventProgress[]
  globalEventMedals   UserGlobalEventMedal[]
  posts               FeedPost[]
  postLikes           PostLike[]
  postComments        PostComment[]
  notifications       Notification[]
  deviceTokens        DeviceToken[]
  reportsFiled        Report[]              @relation("ReportReporter")
  reportsReceived     Report[]              @relation("ReportTargetUser")
  qrSessionsScanned   QrSession[]           @relation("QrScannedBy")

  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model EmailVerification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

model PasswordReset {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

model Bar {
  id           String   @id @default(uuid()) @db.Uuid
  ownerUserId  String   @unique @map("owner_user_id") @db.Uuid
  businessName String   @map("business_name")
  slug         String   @unique
  description  String?
  address      String?
  city         String?
  country      String?
  phone        String?
  logoUrl      String?  @map("logo_url")
  bannerUrl    String?  @map("banner_url")
  latitude     Float?
  longitude    Float?
  /// Horario de apertura estructurado: { days: [{ day, closed, open, close }] }
  openingHours Json?    @map("opening_hours")
  isVerified   Boolean  @default(false) @map("is_verified")
  isActive     Boolean  @default(true) @map("is_active")
  /// El bar declara terraza o jardín (Legend).
  hasOutdoorSpace Boolean @default(false) @map("has_outdoor_space")
  rooftopStatus RooftopVerificationStatus @default(NONE) @map("rooftop_status")
  rooftopRejectionReason String? @map("rooftop_rejection_reason")
  rooftopReviewedAt DateTime? @map("rooftop_reviewed_at")
  rooftopReviewedByAdminId String? @map("rooftop_reviewed_by_admin_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  owner         User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  menuItems     BarMenuItem[]
  qrSessions    QrSession[]
  subscription  BarSubscription?
  promotions    BarPromotion[]
  specialDrinks   BarSpecialDrink[]
  missionSeasons  BarMissionSeason[]
  userBarMedals   UserBarMedal[]
  rooftopPackages BarRooftopPackage[]
  venueEvents     BarVenueEvent[]
  reservations    BarReservation[]
  globalEventBars GlobalEventBar[]
  magazineEditorials MagazineEditorial[]

  @@index([slug])
  @@index([deletedAt])
  @@index([rooftopStatus])
  @@map("bars")
}

/// Evento publicitario del lugar (Legend). Publicación directa con aceptación de políticas;
/// el admin puede retirarlo si incumple.
model BarVenueEvent {
  id                 String                      @id @default(uuid()) @db.Uuid
  barId              String                      @map("bar_id") @db.Uuid
  title              String
  description        String?
  imageUrl           String?                     @map("image_url")
  startsAt           DateTime                    @map("starts_at")
  endsAt             DateTime                    @map("ends_at")
  status             VenueEventStatus            @default(DRAFT)
  moderationStatus   VenueEventModerationStatus  @default(VISIBLE) @map("moderation_status")
  removalReason      String?                     @map("removal_reason")
  removedByAdminId   String?                     @map("removed_by_admin_id") @db.Uuid
  removedAt          DateTime?                   @map("removed_at")
  policiesAcceptedAt DateTime?                   @map("policies_accepted_at")
  createdAt          DateTime                    @default(now()) @map("created_at")
  updatedAt          DateTime                    @updatedAt @map("updated_at")
  deletedAt          DateTime?                   @map("deleted_at")

  bar Bar @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@index([barId])
  @@index([status])
  @@index([moderationStatus])
  @@index([startsAt, endsAt])
  @@index([deletedAt])
  @@map("bar_venue_events")
}

/// Reserva de mesa en un bar Legend. Sin depósito.
model BarReservation {
  id           String              @id @default(uuid()) @db.Uuid
  barId        String              @map("bar_id") @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  guestName    String              @map("guest_name")
  partySize    Int                 @map("party_size")
  reservedFor  DateTime            @map("reserved_for")
  notes        String?
  status       BarReservationStatus @default(PENDING)
  barResponse  String?             @map("bar_response")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  resolvedAt   DateTime?           @map("resolved_at")

  bar  Bar  @relation(fields: [barId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([barId, status])
  @@index([userId, status])
  @@index([reservedFor])
  @@map("bar_reservations")
}

/// Campaña global DrinkQuest. Solo bares Legend pueden formar el pool.
model GlobalEvent {
  id               String             @id @default(uuid()) @db.Uuid
  title            String
  description      String
  imageUrl         String?            @map("image_url")
  goalType         GlobalEventGoalType @default(VISIT_BARS) @map("goal_type")
  targetCount      Int                @default(3) @map("target_count")
  startsAt         DateTime           @map("starts_at")
  endsAt           DateTime           @map("ends_at")
  status           GlobalEventStatus  @default(DRAFT)
  medalTitle       String             @map("medal_title")
  medalDescription String             @map("medal_description")
  createdByAdminId String?            @map("created_by_admin_id") @db.Uuid
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")

  bars     GlobalEventBar[]
  progress UserGlobalEventProgress[]
  medals   UserGlobalEventMedal[]

  @@index([status])
  @@index([startsAt, endsAt])
  @@index([deletedAt])
  @@map("global_events")
}

model GlobalEventBar {
  id        String   @id @default(uuid()) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  barId     String   @map("bar_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  event GlobalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bar   Bar         @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@unique([eventId, barId])
  @@index([barId])
  @@map("global_event_bars")
}

model UserGlobalEventProgress {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  eventId     String    @map("event_id") @db.Uuid
  progress    Int       @default(0)
  completedAt DateTime? @map("completed_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  event GlobalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("user_global_event_progress")
}

model UserGlobalEventMedal {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  event GlobalEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("user_global_event_medals")
}

/// Bebida especializada del local (Intermedio: 3 COMMON; Legend: 5C/3R/2E/1L). Revisión admin.
model BarSpecialDrink {
  id                 String                     @id @default(uuid()) @db.Uuid
  barId              String                     @map("bar_id") @db.Uuid
  name               String
  recipe             String
  funFact            String                     @map("fun_fact")
  imageUrl           String                     @map("image_url")
  rarity             DrinkRarity                @default(COMMON)
  isLimitedEdition   Boolean                    @default(true) @map("is_limited_edition")
  status             SpecialDrinkStatus         @default(DRAFT)
  approvalStatus     SpecialDrinkApprovalStatus @default(PENDING_REVIEW) @map("approval_status")
  rejectionReason    String?                    @map("rejection_reason")
  moderatedByAdminId String?                    @map("moderated_by_admin_id") @db.Uuid
  moderatedAt        DateTime?                  @map("moderated_at")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")
  deletedAt          DateTime?                  @map("deleted_at")

  bar               Bar    @relation(fields: [barId], references: [id], onDelete: Cascade)
  materializedDrink Drink?

  @@index([barId])
  @@index([approvalStatus])
  @@index([status])
  @@index([deletedAt])
  @@map("bar_special_drinks")
}

/// Paquete Rooftop (comida + bebidas). Solo si admin aprobó terraza/jardín del bar Legend.
model BarRooftopPackage {
  id                 String                       @id @default(uuid()) @db.Uuid
  barId              String                       @map("bar_id") @db.Uuid
  title              String
  description        String?
  imageUrl           String                       @map("image_url")
  includesFood       Boolean                      @default(true) @map("includes_food")
  includesDrinks     Boolean                      @default(true) @map("includes_drinks")
  priceLabel         String?                      @map("price_label")
  startsAt           DateTime                     @map("starts_at")
  endsAt             DateTime                     @map("ends_at")
  status             RooftopPackageStatus         @default(DRAFT)
  approvalStatus     RooftopPackageApprovalStatus @default(PENDING_REVIEW) @map("approval_status")
  rejectionReason    String?                      @map("rejection_reason")
  moderatedByAdminId String?                      @map("moderated_by_admin_id") @db.Uuid
  moderatedAt        DateTime?                    @map("moderated_at")
  createdAt          DateTime                     @default(now()) @map("created_at")
  updatedAt          DateTime                     @updatedAt @map("updated_at")
  deletedAt          DateTime?                    @map("deleted_at")

  bar Bar @relation(fields: [barId], references: [id], onDelete: Cascade)

  @@index([barId])
  @@index([status])
  @@index([approvalStatus])
  @@index([startsAt, endsAt])
  @@index([deletedAt])
  @@map("bar_rooftop_packages")
}

/// Temporada de 3 misiones del local (Legend) → 1 medalla del bar.
model BarMissionSeason {
  id               String                 @id @default(uuid()) @db.Uuid
  barId            String                 @map("bar_id") @db.Uuid
  title            String
  startsAt         DateTime               @map("starts_at")
  endsAt           DateTime               @map("ends_at")
  status           BarMissionSeasonStatus @default(DRAFT)
  medalTitle       String                 @map("medal_title")
  medalDescription String                 @map("medal_description")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  deletedAt        DateTime?              @map("deleted_at")

  bar          Bar              @relation(fields: [barId], references: [id], onDelete: Cascade)
  missions     BarMission[]
  medalUnlocks UserBarMedal[]

  @@index([barId])
  @@index([status])
  @@index([startsAt, endsAt])
  @@index([deletedAt])
  @@map("bar_mission_seasons")
}

model BarMission {
  id          String            @id @default(uuid()) @db.Uuid
  seasonId    String            @map("season_id") @db.Uuid
  template    BarMissionTemplate
  title       String
  description String
  targetCount Int               @default(1) @map("target_count")
  sortOrder   Int               @default(0) @map("sort_order")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  season    BarMissionSeason         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  progress  UserBarMissionProgress[]

  @@index([seasonId])
  @@map("bar_missions")
}

model UserBarMissionProgress {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  missionId   String    @map("mission_id") @db.Uuid
  progress    Int       @default(0)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission BarMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@unique([userId, missionId])
  @@index([userId])
  @@map("user_bar_mission_progress")
}

/// Una medalla por temporada del local (Legend).
model UserBarMedal {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  barId      String   @map("bar_id") @db.Uuid
  seasonId   String   @map("season_id") @db.Uuid
  unlockedAt DateTime @default(now()) @map("unlocked_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  bar    Bar              @relation(fields: [barId], references: [id], onDelete: Cascade)
  season BarMissionSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@unique([userId, seasonId])
  @@index([userId])
  @@index([barId])
  @@map("user_bar_medals")
}

/// Promoción publicada por un local (visible en feed USER si acceso SaaS válido).
model BarPromotion {
  id             String                   @id @default(uuid()) @db.Uuid
  barId          String                   @map("bar_id") @db.Uuid
  title          String
  description    String?
  imageUrl       String?                  @map("image_url")
  startsAt       DateTime                 @map("starts_at")
  endsAt         DateTime                 @map("ends_at")
  status         PromotionStatus          @default(DRAFT)
  priority       Int                      @default(0)
  placementType  PromotionPlacementType   @default(STANDARD) @map("placement_type")
  eventTheme     PromotionEventTheme      @default(STANDARD) @map("event_theme")
  approvalStatus PromotionApprovalStatus  @default(PENDING_REVIEW) @map("approval_status")
  rejectionReason String?                 @map("rejection_reason")
  moderatedByAdminId String?              @map("moderated_by_admin_id") @db.Uuid
  moderatedAt    DateTime?                @map("moderated_at")
  rankingScore   Float                    @default(0) @map("ranking_score")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")

  bar Bar @relation(fields: [barId], references: [id], onDelete: Cascade)
  events BarPromotionEvent[]
  analyticsEvents PromotionAnalyticsEvent[]

  @@index([barId])
  @@index([status])
  @@index([startsAt])
  @@index([endsAt])
  @@index([placementType])
  @@index([eventTheme])
  @@index([approvalStatus])
  @@index([moderatedByAdminId])
  @@index([rankingScore])
  @@map("bar_promotions")
}

model BarPromotionEvent {
  id          String            @id @default(uuid()) @db.Uuid
  promotionId String            @map("promotion_id") @db.Uuid
  barId       String            @map("bar_id") @db.Uuid
  eventType   PromotionEventType @map("event_type")
  actorUserId String?           @map("actor_user_id") @db.Uuid
  reason      String?
  payload     Json?             @db.JsonB
  createdAt   DateTime          @default(now()) @map("created_at")

  promotion BarPromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId, createdAt])
  @@index([barId, createdAt])
  @@map("bar_promotion_events")
}

model PromotionAnalyticsEvent {
  id          String                    @id @default(uuid()) @db.Uuid
  promotionId String                    @map("promotion_id") @db.Uuid
  userId      String?                   @map("user_id") @db.Uuid
  eventType   PromotionAnalyticsEventType @map("event_type")
  metadata    Json?                     @db.JsonB
  createdAt   DateTime                  @default(now()) @map("created_at")

  promotion BarPromotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId, createdAt])
  @@index([eventType, createdAt])
  @@index([userId])
  @@map("promotion_analytics_events")
}

/// Suscripción 1:1 del local — facturación, trial y flags operativos (QR / promos).
model BarSubscription {
  id                   String             @id @default(uuid()) @db.Uuid
  barId                String             @unique @map("bar_id") @db.Uuid
  status               SubscriptionStatus @default(TRIAL)
  plan                 SubscriptionPlan   @default(EXPLORER)
  currentPeriodEnd     DateTime?          @map("current_period_end")
  trialEndsAt          DateTime?          @map("trial_ends_at")
  qrEnabled            Boolean            @default(true) @map("qr_enabled")
  promoEnabled         Boolean            @default(true) @map("promo_enabled")
  canceledAt           DateTime?          @map("canceled_at")
  stripeCustomerId     String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?            @unique @map("stripe_subscription_id")
  metadata             Json?              @db.JsonB
  updatedByAdminId     String?            @map("updated_by_admin_id") @db.Uuid
  lastStatusChangedAt  DateTime?          @map("last_status_changed_at")
  statusReason         String?            @map("status_reason")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  bar    Bar                    @relation(fields: [barId], references: [id], onDelete: Cascade)
  events BarSubscriptionEvent[]

  @@index([status])
  @@index([currentPeriodEnd])
  @@index([trialEndsAt])
  @@index([updatedByAdminId])
  @@map("bar_subscriptions")
}

/// Historial de cambios para auditoría, panel admin y webhooks Stripe.
model BarSubscriptionEvent {
  id             String                @id @default(uuid()) @db.Uuid
  subscriptionId String                @map("subscription_id") @db.Uuid
  barId          String                @map("bar_id") @db.Uuid
  eventType      SubscriptionEventType @map("event_type")
  actorUserId    String?               @map("actor_user_id") @db.Uuid
  actorSource    String                @default("admin") @map("actor_source")
  previousStatus SubscriptionStatus?   @map("previous_status")
  newStatus      SubscriptionStatus?   @map("new_status")
  reason         String?
  payload        Json?                 @db.JsonB
  createdAt      DateTime              @default(now()) @map("created_at")

  subscription BarSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([barId, createdAt])
  @@index([subscriptionId])
  @@map("bar_subscription_events")
}

model DrinkCategory {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  drinks Drink[]

  @@map("drink_categories")
}

model Drink {
  id                   String      @id @default(uuid()) @db.Uuid
  legacyId             Int?        @unique @map("legacy_id")
  slug                 String      @unique
  name                 String
  categoryId           String      @map("category_id") @db.Uuid
  rarity               DrinkRarity @default(COMMON)
  imageKey             String?     @map("image_key")
  imageUrl             String?     @map("image_url")
  description          String?
  ingredients          String?
  flavorProfile        String?     @map("flavor_profile")
  alcoholLevel         String?     @map("alcohol_level")
  baseAlcohol          String?     @map("base_alcohol")
  difficulty           String?
  xpReward             Int         @default(10) @map("xp_reward")
  countryOrigin        String?     @map("country_origin")
  isPalomaFamily       Boolean     @default(false) @map("is_paloma_family")
  containsMezcal       Boolean     @default(false) @map("contains_mezcal")
  /// Si no es null, esta bebida materializa una BarSpecialDrink (fuera del catálogo 1–100).
  sourceSpecialDrinkId String?     @unique @map("source_special_drink_id") @db.Uuid
  originBarId          String?     @map("origin_bar_id") @db.Uuid
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  deletedAt            DateTime?   @map("deleted_at")

  category             DrinkCategory     @relation(fields: [categoryId], references: [id])
  sourceSpecialDrink   BarSpecialDrink?  @relation(fields: [sourceSpecialDrinkId], references: [id], onDelete: SetNull)
  barMenuItems         BarMenuItem[]
  qrSessions           QrSession[]
  unlocks              UserDrinkUnlock[]
  history              DrinkHistoryEntry[]
  favorites            UserFavoriteDrink[]
  magazineEditorials   MagazineEditorial[]

  @@index([categoryId])
  @@index([rarity])
  @@index([deletedAt])
  @@index([originBarId])
  @@map("drinks")
}

model BarMenuItem {
