# ─── Application ───────────────────────────────────────────────
NODE_ENV=development

# Puerto HTTP (Render/Railway asignan PORT; API_PORT es alias local/Docker)
PORT=3000
API_PORT=3000
# Host de escucha (producción en Render: 0.0.0.0)
HOST=0.0.0.0
API_PREFIX=api/v1
APP_NAME=DrinkQuest API

# URL pública del servidor (emails, deep links). Sin barra final.
# Producción: https://api.tudominio.com
APP_URL=http://localhost:3000

# URL base para apps cliente (Android, web). Incluye /api/v1
# Producción: https://api.tudominio.com/api/v1
API_BASE_URL=http://localhost:3000/api/v1

# Orígenes CORS (lista separada por comas). Producción: dominios explícitos, sin *
# Apps Android/iOS sin cabecera Origin no requieren estar en esta lista.
# Incluye tu frontend web; la API también fusiona APP_URL y el host Render por defecto (Swagger /docs).
# Web/admin: https://admin.tudominio.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://10.0.2.2:3000,https://drinkquest-api.onrender.com

# Detrás de Cloudflare + Render (IP real vía X-Forwarded-For / CF-Connecting-IP)
TRUST_PROXY=true

# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=drinkquest
POSTGRES_PASSWORD=drinkquest_secret_change_me
POSTGRES_DB=drinkquest
POSTGRES_PORT=5432
DATABASE_URL=postgresql://drinkquest:drinkquest_secret_change_me@postgres:5432/drinkquest?schema=public

# ─── JWT (openssl rand -base64 64) ─────────────────────────────
# Opción A: secretos separados (recomendado)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
# Opción B: un solo secreto (solo si no defines ACCESS/REFRESH)
# JWT_SECRET=change_me_single_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_change_me
REDIS_URL=redis://:redis_secret_change_me@redis:6379

# ─── MinIO (S3-compatible) ─────────────────────────────────────
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=auto
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret_change_me
MINIO_BUCKET=drinkquest
# URL pública de archivos (producción: CDN Cloudflare → R2)
# Ejemplo: https://cdn.tudominio.com  (path-style: …/drinkquest/feed/uuid.jpg)
MINIO_PUBLIC_URL=http://localhost:9000/drinkquest

# ─── Email (SMTP) ────────────────────────────────────────────
# Local: MAIL_ENABLED=false (register works without SMTP)
# Production: MAIL_ENABLED=true + real SMTP_HOST
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@drinkquest.com

# ─── QR sessions ───────────────────────────────────────────────
QR_SESSION_TTL_MINUTES=10

# ─── Rate limiting ─────────────────────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
THROTTLE_AUTH_LIMIT=20

# ─── Suscripciones bares (SaaS) ──────────────────────────────
# Días de trial al registrar un negocio BAR
BAR_TRIAL_DAYS=14

# ─── Stripe (pagos SaaS bares) ───────────────────────────────
# Dashboard: https://dashboard.stripe.com — modo test para desarrollo
STRIPE_SECRET_KEY=sk_test_change_me
STRIPE_WEBHOOK_SECRET=whsec_change_me
# Price IDs de suscripción mensual MXN (Products → cada plan → Pricing → API ID)
STRIPE_PRICE_EXPLORER=price_change_me_explorer
STRIPE_PRICE_INTERMEDIATE=price_change_me_intermediate
STRIPE_PRICE_LEGEND=price_change_me_legend
# Deep links de retorno a la app Android (Stripe sustituye {CHECKOUT_SESSION_ID})
STRIPE_CHECKOUT_SUCCESS_URL=drinkquest://business/subscription?status=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=drinkquest://business/subscription?status=cancel

# ─── Seed admin (first deploy) ───────────────────────────────
SEED_ADMIN_EMAIL=admin@drinkquest.app
SEED_ADMIN_PASSWORD=ChangeMeAdmin123!

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=./logs
